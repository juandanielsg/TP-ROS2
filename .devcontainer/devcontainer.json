{
    "name": "TurtleBot4 ROS2 Humble",
    "dockerComposeFile": "../docker/docker-compose.yml",
    "service": "turtlebot4-sim",
    "workspaceFolder": "/ros_ws",
    "shutdownAction": "stopCompose",
    "initializeCommand": "xhost +local:docker",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-iot.vscode-ros",
                "ms-python.python",
                "ms-vscode.cpptools",
                "ms-vscode.cmake-tools",
                "twxs.cmake"
            ],
            "settings": {
                "ros.distro": "humble"
            }
        }
    }
}
